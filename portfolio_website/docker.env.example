# Copy this file to portfolio_website/docker.env on each machine.
# Keep portfolio_website/docker.env uncommitted.

# Local example:
# DEBUG=true
# ALLOWED_HOSTS=localhost,127.0.0.1,admin.localhost
# CSRF_TRUSTED_ORIGINS=http://localhost,http://127.0.0.1,http://admin.localhost
#
# Production example:
# DEBUG=false
# ALLOWED_HOSTS=keremboylu.com.tr,www.keremboylu.com.tr,admin.keremboylu.com.tr
# CSRF_TRUSTED_ORIGINS=https://keremboylu.com.tr,https://www.keremboylu.com.tr,https://admin.keremboylu.com.tr
# PUBLIC_SITE_ORIGIN=https://keremboylu.com.tr

DEBUG=true
SECRET_KEY=change-me
ALLOWED_HOSTS=localhost,127.0.0.1,admin.localhost
CSRF_TRUSTED_ORIGINS=http://localhost,http://127.0.0.1,http://admin.localhost
PUBLIC_SITE_ORIGIN=

DATABASE_URL=postgres://portfolio_user:portfolio_password@postgres:5432/portfolio_db
POSTGRES_USER=portfolio_user
POSTGRES_PASSWORD=portfolio_password
POSTGRES_DB=portfolio_db

AWS_ACCESS_KEY_ID=replace-with-access-key
AWS_SECRET_ACCESS_KEY=replace-with-secret-key
AWS_STORAGE_BUCKET_NAME_PROD=replace-with-production-bucket
AWS_STORAGE_BUCKET_NAME_DEV=replace-with-development-bucket
AWS_S3_REGION_NAME=replace-with-region

RESEND_API_KEY=re_xxxxxxxxx
DEFAULT_FROM_EMAIL=Your Name <mail@your-verified-domain.com>
DEFAULT_RECEIVER_EMAIL=you@example.com

TURNSTILE_SITE_KEY=1x00000000000000000000AA
TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA
